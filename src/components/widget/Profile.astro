---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
---
<div class="card-base p-4">
    <div class="flex items-start gap-3 mb-3">
        <a
            aria-label="Go to About Page"
            href={url('/about/')}
            class="group block relative w-[5.5rem] h-[5.5rem] overflow-hidden rounded-xl shrink-0 active:scale-95"
        >
            <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="w-full h-full" />
            <div class="absolute inset-0 transition bg-black/0 group-hover:bg-black/20" />
        </a>
        <div class="min-w-0">
            <div class="font-bold text-xl text-90 leading-tight mb-1">{config.name}</div>
            <div class="text-sm text-50 leading-relaxed">{config.bio}</div>
            <a href={url('/about/')} class="link-lg inline-flex mt-2 text-sm font-semibold text-[var(--primary)]">
                Read profile
            </a>
        </div>
    </div>

    <div class="flex flex-wrap gap-2 mb-3">
        <span class="btn-regular rounded-lg px-2.5 py-1 text-xs font-semibold uppercase tracking-wide">Web</span>
        <span class="btn-regular rounded-lg px-2.5 py-1 text-xs font-semibold uppercase tracking-wide">API</span>
        <span class="btn-regular rounded-lg px-2.5 py-1 text-xs font-semibold uppercase tracking-wide">CTF</span>
    </div>

    <div class="rounded-xl border border-dashed border-black/10 dark:border-white/15 px-3 py-2 text-xs text-50 mb-3">
        Tiny mascot accent zone reserved for future custom art.
    </div>

    <div class="flex flex-wrap gap-2">
        {config.links.length > 1 && config.links.map((item) =>
            <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                <Icon name={item.icon} class="text-[1.4rem]" />
            </a>
        )}
        {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
            class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
            <Icon name={config.links[0].icon} class="text-[1.4rem]" />
            {config.links[0].name}
        </a>}
    </div>
</div>

