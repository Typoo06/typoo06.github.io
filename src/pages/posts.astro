---
import PostPage from "@components/PostPage.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCategoryUrl } from "@utils/url-utils";
import { getCategoryList, getSortedPosts } from "@utils/content-utils";

const posts = await getSortedPosts();
const categories = await getCategoryList();

const page = { data: posts };
---

<MainGridLayout title="Posts" description="Security learning posts, writeups, and practical notes">
	<section class="card-base px-6 md:px-9 py-6 mb-4 onload-animation">
		<p class="text-xs uppercase tracking-[0.2em] text-50 mb-2">Posts</p>
		<h1 class="text-3xl md:text-4xl font-bold text-90 mb-3">Security Notes And Writeups</h1>
		<p class="text-50 mb-5 max-w-3xl">
			A complete list of published entries focused on pentest practice, bug bounty workflows,
			and technical notes.
		</p>
		<div class="flex flex-wrap gap-2">
			{categories.map((category) => (
				<a
					href={getCategoryUrl(category.name)}
					class="btn-regular rounded-lg px-3 py-1.5 text-sm font-medium"
				>
					{category.name} ({category.count})
				</a>
			))}
		</div>
	</section>

	<PostPage page={page} />
</MainGridLayout>
