---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getSortedPosts } from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

const posts = await getSortedPosts();
const projectPosts = posts.filter((post) => post.data.category === "Projects");
---

<MainGridLayout
	title="Projects"
	description="Security projects, lab tools, and practical experiments"
>
	<section class="card-base px-6 md:px-9 py-6 mb-4 onload-animation">
		<div class="flex items-center justify-between gap-4 flex-wrap mb-3">
			<div>
				<p class="text-xs uppercase tracking-[0.2em] text-50 mb-2">Projects</p>
				<h1 class="text-3xl md:text-4xl font-bold text-90">Security Project Portfolio</h1>
			</div>
			<span class="btn-regular rounded-lg px-3 py-1.5 text-xs font-semibold uppercase tracking-wide">
				Hachi-style accent reserved
			</span>
		</div>
		<p class="text-50 max-w-3xl">
			A focused list of labs, scripts, and learning projects. This section is intentionally clean,
			with room for subtle mascot accents and future visual assets.
		</p>
	</section>

	{projectPosts.length > 0 ? (
		<div class="grid gap-4 mb-4">
			{projectPosts.map((post, index) => (
				<a
					href={getPostUrlBySlug(post.slug)}
					class="card-base block px-6 md:px-8 py-5 group onload-animation"
					style={`animation-delay: calc(var(--content-delay) + ${index * 60}ms)`}
				>
					<div class="flex justify-between items-start gap-4">
						<div class="min-w-0">
							<h2 class="text-2xl font-bold text-90 group-hover:text-[var(--primary)] transition mb-2">
								{post.data.title}
							</h2>
							<p class="text-50 line-clamp-2 mb-3">{post.data.description}</p>
							<div class="flex flex-wrap gap-2">
								{post.data.tags.map((tag) => (
									<span class="btn-regular rounded-lg px-2.5 py-1 text-xs font-medium">
										#{tag}
									</span>
								))}
							</div>
						</div>
						<div class="text-right text-sm text-50 whitespace-nowrap">
							<div class="mb-1">{formatDateToYYYYMMDD(post.data.published)}</div>
							<div class="inline-flex items-center text-[var(--primary)] font-semibold">
								View
								<Icon name="material-symbols:arrow-right-alt-rounded" class="text-xl" />
							</div>
						</div>
					</div>
				</a>
			))}
		</div>
	) : (
		<section class="card-base px-6 md:px-8 py-6 onload-animation">
			<h2 class="text-xl font-bold text-90 mb-2">No project posts yet</h2>
			<p class="text-50 mb-4">
				Create posts with category set to Projects to automatically populate this portfolio section.
			</p>
			<p class="text-sm text-50">
				Suggested content: tooling experiments, custom recon scripts, lab automation, and writeup-linked repositories.
			</p>
		</section>
	)}
</MainGridLayout>
