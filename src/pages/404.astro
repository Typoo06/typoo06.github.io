---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { url } from "@utils/url-utils";
---

<MainGridLayout title="404" description="Page not found">
	<section class="card-base px-6 md:px-10 py-10 text-center onload-animation">
		<p class="text-xs uppercase tracking-[0.2em] text-50 mb-3">404</p>
		<h1 class="text-4xl md:text-5xl font-bold text-90 mb-3">Page Not Found</h1>
		<p class="text-50 max-w-xl mx-auto mb-6">
			The page may have moved, the link may be outdated, or the URL might be mistyped.
		</p>

		<div class="rounded-xl border border-dashed border-black/10 dark:border-white/15 px-4 py-3 text-sm text-50 mb-6 max-w-xl mx-auto">
			Small mascot illustration placeholder: reserved for future custom artwork.
		</div>

		<div class="flex flex-wrap gap-2 justify-center">
			<a href={url("/")} class="btn-regular rounded-lg px-4 py-2 font-semibold">Go Home</a>
			<a href={url("/posts/")} class="btn-regular rounded-lg px-4 py-2 font-semibold">Browse Posts</a>
			<a href={url("/archive/")} class="btn-plain rounded-lg px-4 py-2 font-semibold">Open Archive</a>
		</div>
	</section>
</MainGridLayout>
